{
  "manifest_version": 3,
  "name": "Gemini Cookie Sync",
  "version": "1.0.0",
  "description": "Auto-sync Gemini cookies to WebAI-to-API server",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
